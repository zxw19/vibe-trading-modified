# ==========================================
# Vibe-Trading A-share Research Agent 配置
# ==========================================
# 复制此文件为 .env 并填入你的配置

# ---------- 必填：LLM 模型 ----------
# 提供商名称（deepseek / openai / openrouter / gemini / groq / moonshot / zhipu / ollama）
LANGCHAIN_PROVIDER=deepseek

# 模型名称
LANGCHAIN_MODEL_NAME=deepseek-v4-pro

# API 密钥
DEEPSEEK_API_KEY=sk-your-api-key-here

# API 地址（DeepSeek 默认地址如下，OpenAI 等不需要设）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------- 可选：A-share 数据源 ----------
# Tushare token（免费注册 https://tushare.pro）
# TUSHARE_TOKEN=your-tushare-token

# 问财 AI 搜索 key
# VIBE_TRADING_IWENCAI_KEY=your-iwencai-key

# ---------- 可选：Shell 工具开关 ----------
# 设为 1 允许 Agent 执行 bash 命令
# VIBE_TRADING_ENABLE_SHELL_TOOLS=1

# ---------- 可选：超时与重试 ----------
# TIMEOUT_SECONDS=300
# MAX_RETRIES=2
